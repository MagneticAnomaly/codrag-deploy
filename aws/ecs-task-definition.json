{
  "_comment": "CoDRAG Headless — AWS ECS Task Definition (reference). Adjust family, executionRoleArn, and environment values for your VPC.",
  "family": "codrag-headless-sync",
  "requiresCompatibilities": ["EC2"],
  "networkMode": "awsvpc",
  "cpu": "4096",
  "memory": "16384",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::YOUR_ACCOUNT:role/codragHeadlessRole",
  "containerDefinitions": [
    {
      "name": "codrag-headless",
      "image": "ghcr.io/ericbintner/codrag-headless:gpu",
      "essential": true,
      "command": [
        "sync-headless",
        "--repo-path", "/workspace",
        "--branch", "main",
        "--model-provider", "local",
        "--model-name", "qwen3:4b",
        "--embedder", "native"
      ],
      "environment": [
        { "name": "CODRAG_S3_BUCKET", "value": "my-internal-codrag-indexes" },
        { "name": "CODRAG_S3_PREFIX", "value": "my-repo/main" }
      ],
      "secrets": [
        { "name": "CODRAG_S3_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT:secret:codrag/s3-access-key" },
        { "name": "CODRAG_S3_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT:secret:codrag/s3-secret-key" }
      ],
      "resourceRequirements": [
        { "type": "GPU", "value": "1" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/codrag-headless",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "sync"
        }
      },
      "mountPoints": [
        { "sourceVolume": "workspace", "containerPath": "/workspace" }
      ]
    }
  ],
  "volumes": [
    { "name": "workspace", "host": {} }
  ]
}
